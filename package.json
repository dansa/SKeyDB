{
  "name": "skeydb",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.{js,mjs,cjs}\" \"src/data/**/*.json\" \"src/domain/persistence-contract.v1.json\" \"schemas/**/*.json\" \"package.json\" \"tools/react-sidecar/package.json\" \"eslint.config.js\" \"vite.config.ts\" \"prettier.config.cjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.{js,mjs,cjs}\" \"src/data/**/*.json\" \"src/domain/persistence-contract.v1.json\" \"schemas/**/*.json\" \"package.json\" \"tools/react-sidecar/package.json\" \"eslint.config.js\" \"vite.config.ts\" \"prettier.config.cjs\"",
    "lint": "eslint src scripts vite.config.ts eslint.config.js",
    "lint:react-sidecar": "node tools/react-sidecar/node_modules/eslint/bin/eslint.js --config tools/react-sidecar/eslint.config.js \"src/**/*.{tsx,jsx}\"",
    "lint:react-sidecar:setup": "npm install --prefix tools/react-sidecar",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run --run --exclude src/pages/BuilderPage*.test.tsx",
    "test:integration": "vitest run --run src/pages/BuilderPage.awakener-basics.test.tsx src/pages/BuilderPage.team-management.test.tsx src/pages/BuilderPage.quick-lineup.test.tsx src/pages/BuilderPage.import-export.test.tsx src/pages/BuilderPage.selection.test.tsx src/pages/BuilderPage.covenants.test.tsx src/pages/BuilderPage.wheels.test.tsx",
    "test:quick": "vitest run --run src/pages/CollectionPage.test.tsx src/pages/collection/OwnedWheelBoxExport.test.tsx src/components/ui/DupeLevelDisplay.test.tsx",
    "test:watch": "vitest",
    "verify": "npm run format:check && npm run lint && npm run test -- --run && npm run build",
    "data:sync-awakener-full": "node scripts/sync-awakener-full.mjs",
    "data:sync-awakener-ids": "node scripts/sync-awakener-ids.mjs",
    "data:sync-posse-indices": "node scripts/sync-posse-indices.mjs",
    "data:sync-wheel-data": "node scripts/sync-wheel-data.mjs",
    "prepare": "node scripts/install-git-hooks.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clsx": "^2.1.1",
    "fuse.js": "^7.1.0",
    "html-to-image": "^1.11.13",
    "immer": "^11.1.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/vite": "^0.0.0-insiders.a4be983",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.0.3",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "7.1.0-canary-e0cc7202-20260227",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^0.0.0-insiders.a4be983",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "rollup": "^4.59.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run verify"
  }
}
