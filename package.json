{
  "name": "skeydb",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:quiet": "tsc -b && vite build --logLevel error",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.{js,mjs,cjs}\" \"src/data/**/*.json\" \"src/domain/persistence-contract.v1.json\" \"schemas/**/*.json\" \"package.json\" \"tools/react-sidecar/package.json\" \"eslint.config.js\" \"vite.config.ts\" \"prettier.config.cjs\"",
    "format:changed": "node scripts/format-changed-files.mjs",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.{js,mjs,cjs}\" \"src/data/**/*.json\" \"src/domain/persistence-contract.v1.json\" \"schemas/**/*.json\" \"package.json\" \"tools/react-sidecar/package.json\" \"eslint.config.js\" \"vite.config.ts\" \"prettier.config.cjs\"",
    "assets:webp": "node scripts/convert-png-assets-to-webp.mjs",
    "assets:webp:dry": "node scripts/convert-png-assets-to-webp.mjs --dry-run",
    "lint": "eslint src scripts vite.config.ts eslint.config.js",
    "lint:react-sidecar": "node tools/react-sidecar/node_modules/eslint/bin/eslint.js --config tools/react-sidecar/eslint.config.js \"src/**/*.{tsx,jsx}\"",
    "lint:react-sidecar:setup": "npm install --prefix tools/react-sidecar",
    "preview": "vite preview",
    "test": "vitest run",
    "test:bounded": "vitest run --run --pool=forks --maxWorkers=4",
    "test:unit": "vitest run --run --exclude src/features/builder/BuilderPage*.test.tsx",
    "test:integration": "vitest run --run src/features/builder/BuilderPage.awakener-basics.test.tsx src/features/builder/BuilderPage.team-management.test.tsx src/features/builder/BuilderPage.quick-lineup.test.tsx src/features/builder/BuilderPage.import-export.test.tsx src/features/builder/BuilderPage.selection.test.tsx src/features/builder/BuilderPage.covenants.test.tsx src/features/builder/BuilderPage.wheels.test.tsx",
    "test:quick": "vitest run --run src/features/collection/CollectionPage.test.tsx src/features/collection/OwnedWheelBoxExport.test.tsx src/components/ui/DupeLevelDisplay.test.tsx",
    "test:watch": "vitest",
    "verify": "npm run format && npm run lint && npm run test:bounded && npm run build",
    "verify:pre-commit": "node scripts/pre-commit-verify.mjs",
    "prepare": "node scripts/install-git-hooks.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clsx": "^2.1.1",
    "fuse.js": "^7.3.0",
    "html-to-image": "^1.11.13",
    "immer": "^11.1.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-import-resolver-node": "^0.3.10",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "brace-expansion": "5.0.5",
    "flatted": "3.4.2",
    "rollup": "^4.59.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run verify:pre-commit"
  }
}
