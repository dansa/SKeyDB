{
  "name": "skeydb",
  "private": true,
  "version": "0.0.0",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:quiet": "tsc -b && vite build --logLevel error",
    "format": "prettier --write --ignore-unknown \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.{js,mjs,cjs}\" \"src/data/**/*.json\" \"src/domain/*.json\" \"package.json\" \"tools/react-sidecar/package.json\" \"eslint.config.js\" \"vite.config.ts\" \"vitest.config.ts\" \"prettier.config.cjs\" \"tsconfig*.json\" \".github/workflows/*.yml\" \".prettierignore\"",
    "format:changed": "node scripts/format-changed-files.mjs",
    "format:check": "prettier --check --ignore-unknown \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.{js,mjs,cjs}\" \"src/data/**/*.json\" \"src/domain/*.json\" \"package.json\" \"tools/react-sidecar/package.json\" \"eslint.config.js\" \"vite.config.ts\" \"vitest.config.ts\" \"prettier.config.cjs\" \"tsconfig*.json\" \".github/workflows/*.yml\" \".prettierignore\"",
    "assets:webp": "node scripts/convert-png-assets-to-webp.mjs",
    "assets:webp:dry": "node scripts/convert-png-assets-to-webp.mjs --dry-run",
    "lint": "eslint src scripts vite.config.ts vitest.config.ts eslint.config.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:bounded": "vitest run --run --pool=forks --maxWorkers=4",
    "test:scripts": "node --test scripts/*.test.mjs",
    "test:unit": "vitest run --run --exclude src/features/builder/BuilderPage*.test.tsx",
    "test:integration:builder": "vitest run --run src/features/builder/BuilderPage.awakener-basics.test.tsx src/features/builder/BuilderPage.team-management.test.tsx src/features/builder/BuilderPage.quick-lineup.test.tsx src/features/builder/BuilderPage.import-export.test.tsx src/features/builder/BuilderPage.selection.test.tsx src/features/builder/BuilderPage.covenants.test.tsx src/features/builder/BuilderPage.wheels.test.tsx",
    "test:integration:builder-v2": "vitest run --run src/features/builder-v2/BuilderV2Page.test.tsx src/features/builder-v2/useBuilderV2Model.test.ts src/features/builder-v2/builder-v2-dnd.test.ts",
    "test:integration": "npm run test:integration:builder && npm run test:integration:builder-v2",
    "test:quick": "vitest run --run src/features/collection/CollectionPage.test.tsx src/features/collection/OwnedWheelBoxExport.test.tsx src/components/ui/DupeLevelDisplay.test.tsx",
    "test:watch": "vitest",
    "verify": "npm run format:check && npm run lint && npm run test:bounded && npm run test:scripts && npm run build",
    "verify:pre-commit": "node scripts/pre-commit-verify.mjs",
    "verify:pre-commit:full": "node scripts/pre-commit-verify.mjs --full",
    "prepare": "node scripts/install-git-hooks.mjs",
    "doctor": "react-doctor"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clsx": "^2.1.1",
    "fuse.js": "^7.4.2",
    "html-to-image": "^1.11.13",
    "immer": "^11.1.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-import-resolver-node": "^0.4.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-doctor": "^0.4.0",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "brace-expansion": "5.0.6",
    "flatted": "3.4.2",
    "rollup": "^4.59.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run verify:pre-commit"
  }
}
